# Trinity — Unified Atlassian CLI
# Copy to .env and fill in your values

# ── Atlassian (Jira + Confluence) ─────────────────────────────────────────────
# The email address associated with your Atlassian account / service account
ATLASSIAN_EMAIL=you@yourcompany.com

# API token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your_api_token_here

# Cloud ID — find at: https://your-instance.atlassian.net/_edge/tenant_info
ATLASSIAN_CLOUD_ID=your-cloud-id-here

# Full Jira instance URL (for building web links)
ATLASSIAN_JIRA_URL=https://yourcompany.atlassian.net

# ── Bitbucket ─────────────────────────────────────────────────────────────────
# Repository access token (preferred) — generate in Bitbucket repo settings
BITBUCKET_REPO_TOKEN=your_repo_token_here

# Default workspace slug
BITBUCKET_WORKSPACE=your-workspace
